generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// AUTH (Better Auth required models)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]

  companyMembers CompanyMember[]
  sellerProfiles Seller[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("verification")
}

// ─────────────────────────────────────────────
// MULTI-TENANT CORE
// ─────────────────────────────────────────────

enum CompanyPlan {
  FREE
  PRO
  ENTERPRISE
}

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  SELLER
}

model Company {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  cnpj        String?
  phone       String?
  email       String?
  logo        String?
  plan        CompanyPlan @default(FREE)
  isActive    Boolean     @default(true)
  onboarded   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  members              CompanyMember[]
  sellers              Seller[]
  products             Product[]
  customers            Customer[]
  sales                Sale[]
  commissions          Commission[]
  financialTransactions FinancialTransaction[]
  postSaleActivities   PostSaleActivity[]
  settings             CompanySettings?

  @@map("company")
}

model CompanyMember {
  id        String     @id @default(cuid())
  role      MemberRole @default(SELLER)
  joinedAt  DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
  @@map("company_member")
}

// ─────────────────────────────────────────────
// SELLER — entidade separada do User
// ─────────────────────────────────────────────

enum CommissionType {
  FIXED
  PERCENTAGE
  MIXED
  NONE
}

model Seller {
  id              String         @id @default(cuid())
  code            String
  name            String
  email           String?
  phone           String?
  commissionType  CommissionType @default(NONE)
  commissionValue Decimal        @default(0) @db.Decimal(10, 4)
  commissionRules Json?
  isActive        Boolean        @default(true)
  hiredAt         DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  sales               Sale[]
  commissions         Commission[]
  assignedActivities  PostSaleActivity[] @relation("AssignedSeller")

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@map("seller")
}

// ─────────────────────────────────────────────
// CATALOG
// ─────────────────────────────────────────────

enum ProductType {
  PRODUCT
  SERVICE
  RENTAL
}

model Product {
  id                 String      @id @default(cuid())
  name               String
  sku                String?
  description        String?
  type               ProductType @default(PRODUCT)
  price              Decimal     @default(0) @db.Decimal(10, 2)
  rentalPricePerDay  Decimal?    @db.Decimal(10, 2)
  unit               String?
  stock              Int?
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  saleItems SaleItem[]

  @@unique([companyId, sku])
  @@index([companyId, type, isActive])
  @@map("product")
}

// ─────────────────────────────────────────────
// CRM — CUSTOMERS
// ─────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  document  String?
  address   Json?
  tags      String[]
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  sales Sale[]

  @@index([companyId, email])
  @@index([companyId, name])
  @@map("customer")
}

// ─────────────────────────────────────────────
// SALES
// ─────────────────────────────────────────────

enum SaleType {
  SALE
  RENTAL
  SERVICE
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  DELIVERED
  CANCELLED
  RETURNED
}

model Sale {
  id               String     @id @default(cuid())
  number           Int
  type             SaleType   @default(SALE)
  status           SaleStatus @default(DRAFT)
  totalAmount      Decimal    @default(0) @db.Decimal(10, 2)
  discount         Decimal    @default(0) @db.Decimal(10, 2)
  notes            String?
  saleDate         DateTime   @default(now())
  expectedDelivery DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sellerId   String
  seller     Seller   @relation(fields: [sellerId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  items              SaleItem[]
  commissions        Commission[]
  postSaleActivities PostSaleActivity[]

  @@unique([companyId, number])
  @@index([companyId, sellerId, status, saleDate])
  @@index([companyId, status])
  @@index([companyId, saleDate])
  @@map("sale")
}

model SaleItem {
  id          String   @id @default(cuid())
  description String?
  quantity    Decimal  @db.Decimal(10, 3)
  unitPrice   Decimal  @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  totalPrice  Decimal  @db.Decimal(10, 2)
  rentalStart DateTime?
  rentalEnd   DateTime?
  createdAt   DateTime @default(now())

  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@map("sale_item")
}

// ─────────────────────────────────────────────
// POST-SALE
// ─────────────────────────────────────────────

enum PostSaleType {
  FOLLOWUP
  COMPLAINT
  RETURN
  FEEDBACK
  DELIVERY
  SUPPORT
}

enum ActivityStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

model PostSaleActivity {
  id          String         @id @default(cuid())
  type        PostSaleType   @default(FOLLOWUP)
  status      ActivityStatus @default(OPEN)
  title       String?
  notes       String?
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  saleId             String
  sale               Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  companyId          String
  company            Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedToSellerId String?
  assignedSeller     Seller? @relation("AssignedSeller", fields: [assignedToSellerId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([saleId])
  @@map("post_sale_activity")
}

// ─────────────────────────────────────────────
// COMMISSIONS
// ─────────────────────────────────────────────

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

model Commission {
  id         String           @id @default(cuid())
  baseAmount Decimal          @db.Decimal(10, 2)
  rate       Decimal          @default(0) @db.Decimal(10, 4)
  amount     Decimal          @db.Decimal(10, 2)
  type       CommissionType
  status     CommissionStatus @default(PENDING)
  notes      String?
  paidAt     DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  sellerId  String
  seller    Seller  @relation(fields: [sellerId], references: [id])
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, sellerId, status])
  @@index([companyId, status])
  @@map("commission")
}

// ─────────────────────────────────────────────
// FINANCIAL
// ─────────────────────────────────────────────

enum TransactionType {
  INCOME
  EXPENSE
  COMMISSION_PAYMENT
}

model FinancialTransaction {
  id            String          @id @default(cuid())
  type          TransactionType
  category      String?
  amount        Decimal         @db.Decimal(10, 2)
  description   String?
  referenceId   String?
  referenceType String?
  date          DateTime
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, date])
  @@index([companyId, type])
  @@map("financial_transaction")
}

// ─────────────────────────────────────────────
// COMPANY SETTINGS
// ─────────────────────────────────────────────

model CompanySettings {
  id                     String         @id @default(cuid())
  commissionDefaultType  CommissionType @default(NONE)
  commissionDefaultValue Decimal        @default(0) @db.Decimal(10, 4)
  currency               String         @default("BRL")
  fiscalYear             Int            @default(1)
  customFields           Json?
  updatedAt              DateTime       @updatedAt

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}
