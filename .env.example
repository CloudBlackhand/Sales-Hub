# Database (Railway PostgreSQL)
# No Railway: use a variável que o Postgres do projeto expõe (ex.: copiar "Database URL" do plugin Postgres)
# ou referência ${{ Postgres.DATABASE_URL }} — NÃO deixe o hostname como "host" (exemplo abaixo é só formato).
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-POSTGRES-HOST.railway.internal:5432/railway?schema=public"

# Better Auth
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
# URL pública completa da API (cookies/CORS). Na Railway use o domínio real do serviço (ex.: https://seu-app.up.railway.app).
BETTER_AUTH_URL="https://seu-app.up.railway.app"
# Opcional: mais domínios permitidos no CORS (separados por vírgula).
# BETTER_AUTH_TRUSTED_ORIGINS="https://www.suaempresa.com"

# App (opcional no cliente: sign-in usa o origin do browser automaticamente)
NEXT_PUBLIC_APP_URL="https://seu-app.up.railway.app"
NEXT_PUBLIC_APP_NAME="Sales Hub"

# Supervisão global (/supervise): e-mails separados por vírgula. Se vazio, só o usuário demo do seed tem acesso.
# PLATFORM_ADMIN_EMAILS="ops@suaempresa.com,demo@provedor.com"

# Opcional: diagnóstico GET /api/health/db-auth com header Authorization: Bearer <mesmo valor>
# DB_AUTH_CHECK_SECRET="cole-um-token-longo-aleatorio"

# Opcional: um POST forçado cria/repara o demo no MESMO Postgres da app (útil se o seed no arranque falhou).
# DEMO_BOOTSTRAP_SECRET="token-longo-unico"
# curl -X POST -H "Authorization: Bearer SEU_TOKEN" https://seu-app.up.railway.app/api/health/bootstrap-demo

# Demo: seed no deploy + POST /api/health/bootstrap-demo. Ao arrancar o Next, se não existir o demo nesta BD, corre seed automático (instrumentation).
# Para desligar esse auto-seed: DISABLE_AUTO_DEMO_SEED=1

# ─────────────────────────────────────────────
# OpenPanel (analytics à parte do CRM)
# ─────────────────────────────────────────────
# O OpenPanel é outro stack (dashboard + API + ClickHouse, etc.). Na Railway costuma ser
# um segundo projeto/serviço, separado do Sales Hub. Guia oficial de self-host:
# https://github.com/Openpanel-dev/openpanel/tree/main/self-hosting
# Após subir a instância: cria um projeto na UI OpenPanel e obtém o Client ID (e Client Secret
# para eventos no servidor). No Sales Hub só precisas destas variáveis.
#
# Cliente (browser): obrigatório para carregar o SDK e ecrãs; sem isto o CRM funciona sem analytics.
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=""
# URL da API de ingestão (cloud: normalmente vazio = default). Self-host: base da API OpenPanel (ex.: https://op-api.seudominio.com).
# NEXT_PUBLIC_OPENPANEL_API_URL=""
# URL do script op1.js se não usares o default da cloud (self-host).
# NEXT_PUBLIC_OPENPANEL_SCRIPT_URL=""
# Link “Analytics” na sidebar (OWNER/ADMIN): URL completo do projeto no dashboard OpenPanel; a rota /{slug}/analytics incorpora esta página em iframe (igual UI ao demo).
# Exemplo cloud: https://demo.openpanel.dev/demo/shoey — no teu projeto, copia o URL do browser na visão Overview do workspace.
# NEXT_PUBLIC_OPENPANEL_DASHBOARD_URL="https://demo.openpanel.dev/demo/shoey"
#
# Proxy same-origin (reduz bloqueio por adblock): define NEXT_PUBLIC_OPENPANEL_USE_PROXY=1 e mantém
# a rota /api/op no Next (createRouteHandler). O handler reencaminha para OPENPANEL_API_URL ou
# NEXT_PUBLIC_OPENPANEL_API_URL ou para a API cloud por defeito.
# NEXT_PUBLIC_OPENPANEL_USE_PROXY=1
#
# Servidor (Server Actions — vendas): obrigatório para eventos sale_* / revenue no OpenPanel.
# Não expor o secret no cliente; usa o mesmo Client ID que em NEXT_PUBLIC_OPENPANEL_CLIENT_ID.
# OPENPANEL_CLIENT_ID=""   # opcional se já tens NEXT_PUBLIC_OPENPANEL_CLIENT_ID
OPENPANEL_CLIENT_SECRET=""
# OPENPANEL_API_URL=""     # opcional; alinha com NEXT_PUBLIC_OPENPANEL_API_URL em self-host
#
# Identify / RGPD: o layout autenticado envia IdentifyComponent (id de utilizador da app, e-mail,
# empresa atual) quando NEXT_PUBLIC_OPENPANEL_CLIENT_ID está definido. Garante base legal/consentimento
# conforme o teu contexto (política de privacidade, DPA com fornecedor OpenPanel self-host/cloud).
